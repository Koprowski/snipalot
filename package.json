{
  "name": "snipalot",
  "version": "1.0.7",
  "description": "Portable Windows screen-feedback tool: record, annotate live, transcribe, and hand an LLM-ready prompt to your clipboard.",
  "main": "dist/main/index.js",
  "author": "Jason Koprowski",
  "license": "MIT",
  "private": true,
  "scripts": {
    "kill:stale": "node scripts/kill-stale-processes.mjs",
    "prestart": "npm run kill:stale",
    "predev": "npm run kill:stale",
    "predebug": "npm run kill:stale",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs && node scripts/make-icon.mjs",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron . --dev",
    "debug": "npm run build && electron . --dev --debug",
    "spike:m1": "npm run build && electron . --spike=m1",
    "package": "npm run build && electron-builder",
    "package:nopublish": "npm run build && electron-builder --publish never",
    "package:portable": "npm run build && electron-builder --win portable",
    "fetch-resources": "node scripts/fetch-resources.mjs",
    "clean": "node scripts/clean.mjs",
    "install:safe": "npm run kill:stale && npm install"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "csv-stringify": "^6.7.0",
    "ffmpeg-static": "^5.2.0"
  }
}
